{
  "name": "aquarium-multi",
  "version": "2.0.0",
  "description": "멀티플레이어 아쿠아리움 - 나만의 물고기를 만들어 공유 수조에 넣자",
  "main": "dist-server/index.js",
  "scripts": {
    "dev:client": "vite --config vite.config.ts",
    "dev:server": "tsx watch server/index.ts",
    "build": "vite build --config vite.config.ts && tsc -p tsconfig.node.json",
    "start": "node dist-server/index.js",
    "preview": "node dist-server/index.js"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "express": "^4.18.2",
    "pg": "^8.13.1",
    "socket.io": "^4.7.4",
    "socket.io-client": "^4.7.4"
  },
  "devDependencies": {
    "typescript": "^5.4.0",
    "vite": "^5.4.0",
    "@types/express": "^4.17.21",
    "@types/node": "^20.11.0",
    "@types/pg": "^8.10.9",
    "tsx": "^4.7.0"
  }
}
